{
  "name": "pw-docker",
  "version": "1.0.0",
  "description": "Playwright Grid with Chromium and Firefox",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "grid:up": "docker-compose up -d",
    "grid:down": "docker-compose down",
    "grid:logs": "docker-compose logs -f",
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium-grid",
    "test:firefox": "npx playwright test --project=firefox-grid",
    "test:report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "dependencies": {
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^3.5.0"
  }
}
